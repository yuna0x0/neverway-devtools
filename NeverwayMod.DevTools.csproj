<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Lib.Harmony" Version="2.4.*" />
    <PackageReference Include="ImGui.NET" Version="1.91.*" />
    <PackageReference Include="MurderModLoader.API" Version="0.1.*" />
  </ItemGroup>

  <PropertyGroup>
    <GameAssemblyPath Condition="'$(GameAssemblyPath)' == ''">..\..\lib</GameAssemblyPath>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="Murder">
      <HintPath>$(GameAssemblyPath)\Murder.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Bang">
      <HintPath>$(GameAssemblyPath)\Bang.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="FNA">
      <HintPath>$(GameAssemblyPath)\FNA.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Neverway">
      <HintPath>$(GameAssemblyPath)\Neverway.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
